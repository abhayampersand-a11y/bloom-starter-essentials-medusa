# Database — adjust the password if your local Postgres superuser password differs
DATABASE_URL=postgres://postgres:admin@localhost:5432/bloom_medusa

# CORS (storefront dev ports + admin panel)
STORE_CORS=http://localhost:8000,http://localhost:3000,http://localhost:5173
ADMIN_CORS=http://localhost:9000,http://localhost:5173,http://localhost:7001
AUTH_CORS=http://localhost:8000,http://localhost:3000,http://localhost:5173,http://localhost:9000

# Secrets (dev only — replace in production)
JWT_SECRET=supersecret-dev-jwt
COOKIE_SECRET=supersecret-dev-cookie

# Redis (running in WSL, reachable from Windows on localhost)
REDIS_URL=redis://localhost:6379
